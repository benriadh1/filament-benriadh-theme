{
    "name": "benriadh1/filament-benriadh-theme",
    "description": "A Filament v5 ERP-inspired theme package.",
    "type": "library",
    "license": "MIT",
    "keywords": ["filament", "filament-v5", "theme", "erp", "laravel"],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "illuminate/support": "^11.0 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "Benriadh1\\FilamentBenriadhTheme\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Benriadh1\\FilamentBenriadhTheme\\FilamentBenriadhThemeServiceProvider"
            ]
        },
        "filament": {
            "plugins": [
                "Benriadh1\\FilamentBenriadhTheme\\FilamentBenriadhThemePlugin"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
