{
    "name": "benriadh1/filament-benriadh-theme",
    "description": "A Filament v5 ERP-inspired theme package.",
    "type": "library",
    "license": "MIT",
    "keywords": ["filament", "filament-v5", "theme", "erp", "laravel"],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "illuminate/support": "^11.0 || ^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0 || ^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "laravel/pint": "^1.0"
    },
    "suggest": {
        "benriadh1/filament-translation-manager": "Enables the TranslationManagerAdapter CSS bridge for the translation manager panel."
    },
    "autoload": {
        "psr-4": {
            "Benriadh1\\FilamentBenriadhTheme\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Benriadh1\\FilamentBenriadhTheme\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest",
        "lint": "pint"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Benriadh1\\FilamentBenriadhTheme\\FilamentBenriadhThemeServiceProvider"
            ]
        },
        "filament": {
            "plugins": [
                "Benriadh1\\FilamentBenriadhTheme\\FilamentBenriadhThemePlugin"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
